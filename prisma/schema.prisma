// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(uuid())
  email           String            @unique
  password        String
  displayName     String?           @map("display_name")
  emailVerified   Boolean           @default(false) @map("email_verified")
  verificationToken String?         @unique @map("verification_token")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  apiConfigs      ApiConfig[]
  positions       Position[]
  trades          Trade[]
  accountSnapshots AccountSnapshot[]
  transfers       Transfer[]

  @@map("users")
}

model ApiConfig {
  id                    String    @id @default(uuid())
  userId                String    @map("user_id")
  exchange              String    @default("binance")  // "binance" | "okx"
  apiKeyEncrypted       String    @map("api_key_encrypted")
  apiSecretEncrypted    String    @map("api_secret_encrypted")
  passphraseEncrypted   String?   @map("passphrase_encrypted")  // OKX 专用
  isActive              Boolean   @default(true) @map("is_active")
  lastSyncAt            DateTime? @map("last_sync_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_configs")
}

model Position {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  exchange       String    @default("binance")  // "binance" | "okx"
  symbol         String
  side           String    // 'LONG' or 'SHORT'
  leverage       Int
  status         String    // 'OPEN' or 'CLOSED'
  openTime       DateTime  @map("open_time")
  closeTime      DateTime? @map("close_time")
  avgOpenPrice   Decimal   @map("avg_open_price")
  avgClosePrice  Decimal?  @map("avg_close_price")
  quantity       Decimal
  maxQuantity    Decimal   @map("max_quantity")
  maxPositionValue Decimal @map("max_position_value")
  maxMargin      Decimal   @map("max_margin")
  realizedPnl    Decimal   @map("realized_pnl")
  fee            Decimal   @default(0)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]

  @@index([userId, status])
  @@index([symbol])
  @@map("positions")
}

model Trade {
  id              String   @id @default(uuid())
  positionId      String?  @map("position_id")
  userId          String   @map("user_id")
  exchange        String   @default("binance")          // "binance" | "okx"
  exchangeOrderId String   @map("exchange_order_id")    // 原 binance_order_id，兼容两家交易所
  symbol          String
  side            String   // 'BUY' or 'SELL'
  positionSide    String   @map("position_side")        // 'LONG' or 'SHORT'
  orderType       String   @map("order_type")           // 'LIMIT', 'MARKET', etc.
  quantity        Decimal
  price           Decimal
  fee             Decimal
  realizedPnl     Decimal  @default(0) @map("realized_pnl")
  time            DateTime
  createdAt       DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  position Position? @relation(fields: [positionId], references: [id], onDelete: SetNull)

  @@unique([exchangeOrderId, exchange])   // 复合唯一：同一交易所同一订单ID不重复
  @@index([userId, time])
  @@index([symbol])
  @@map("trades")
}

model AccountSnapshot {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  balance        Decimal
  unrealizedPnl  Decimal  @map("unrealized_pnl")
  totalEquity    Decimal  @map("total_equity")
  netTransfer    Decimal  @default(0) @map("net_transfer")  // 累计净出入金金额（正=净入金，负=净出金）
  snapshotTime   DateTime @map("snapshot_time")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, snapshotTime])
  @@index([userId, snapshotTime])
  @@map("account_snapshots")
}

model Transfer {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  exchange        String   @default("binance")          // "binance" | "okx"
  exchangeTransId String   @map("exchange_trans_id")    // 原 binance_trans_id，兼容两家交易所
  type            String   // DEPOSIT 或 WITHDRAWAL
  amount          Decimal  // 绝对值金额
  asset           String   @default("USDT")
  time            DateTime
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([exchangeTransId, exchange])   // 复合唯一：同一交易所同一转账ID不重复
  @@index([userId, time])
  @@map("transfers")
}
